{
  "tests": [
    {
      "name": "Get all requests",
      "method": "GET",
      "path": "/?action=requests",
      "expectedStatus": 200
    },
    {
      "name": "Get all clients",
      "method": "GET",
      "path": "/?action=clients",
      "expectedStatus": 200
    },
    {
      "name": "Get quiz statistics",
      "method": "GET",
      "path": "/?action=quiz_stats",
      "expectedStatus": 200
    },
    {
      "name": "Create client",
      "method": "POST",
      "path": "/",
      "body": {"action": "create_client", "name": "Тест Клиент", "phone": "+79000000000", "source": "crm"},
      "expectedStatus": 200,
      "expectedBody": {"success": true},
      "bodyMatcher": "partial"
    },
    {
      "name": "Get client properties - missing client_id",
      "method": "GET",
      "path": "/?action=client_properties",
      "expectedStatus": 400
    },
    {
      "name": "Send proposal - missing data",
      "method": "POST",
      "path": "/",
      "body": {"action": "send_proposal"},
      "expectedStatus": 400
    }
  ]
}